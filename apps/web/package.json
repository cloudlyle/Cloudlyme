    "@cloudlyme/types":     "workspace:*",
    "@cloudlyme/hooks":     "workspace:*"
  },
  "devDependencies": {
    "@eslint/js":               "^10.0.1",
    "@tailwindcss/vite":        "^4.3.1",
    "@types/node":              "^26.0.1",
    "@types/react":             "^19.2.14",
    "@types/react-dom":         "^19.2.3",
    "@vitejs/plugin-react":     "^6.0.1",
    "eslint":                   "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages":                 "^6.3.0",
    "globals":                  "^17.6.0",
    "tailwindcss":              "^4.3.1",
    "typescript":               "^6.0.3",
    "typescript-eslint":        "^8.62.0",
    "vite":                     "^8.0.12"
