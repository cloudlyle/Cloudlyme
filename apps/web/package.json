{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://cloudlyle.github.io/Cloudlyme",
  "scripts": {
    "dev":        "vite",
    "build":      "tsc && vite build",
    "preview":    "vite preview",
    "predeploy":  "npm run build",
    "deploy":     "gh-pages -d dist",
    "lint":       "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons":    "^6.2.5",
    "@tanstack/react-query": "^5.101.1",
    "antd":                 "^6.4.5",
    "axios":                "^1.18.1",
    "react":                "^19.2.6",
    "react-dom":            "^19.2.6",
    "react-router-dom":     "6",
    "zustand":              "^5.0.14",
    "@cloudlyme/ui":        "workspace:*",
